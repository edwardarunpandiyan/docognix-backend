# ============================================================
# Docognix Backend – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="Docognix API"
APP_VERSION="1.0.0"
DEBUG=false
API_PREFIX="/api/v1"

# ── CORS (comma-separated list is fine for pydantic-settings)
# Add your Vercel/Netlify URL when deployed
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'

# ── Supabase PostgreSQL ───────────────────────────────────────
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Get this from: Supabase Dashboard → Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Upstash Redis ─────────────────────────────────────────────
# Format: rediss://default:<token>@<hostname>.upstash.io:6379
# Get this from: Upstash Console → Your Database → Details → Redis URL
UPSTASH_REDIS_URL=rediss://default:<token>@<hostname>.upstash.io:6379
UPSTASH_REDIS_TOKEN=<your-upstash-rest-token>

# ── Groq API (FREE at groq.com) ───────────────────────────────
# Sign up free at https://console.groq.com
# Primary model: llama-3.3-70b-versatile  (best quality, free)
# Fallback model: llama-3.1-8b-instant    (used for HyDE, fast)
GROQ_API_KEY=gsk_<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ── Embedding Model (local, downloaded on first run) ──────────
# Model is cached in ~/.cache/huggingface after first download (~130 MB)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── RAG Pipeline Tuning ───────────────────────────────────────
CHUNK_SIZE=512              # target tokens per chunk
CHUNK_OVERLAP=64            # overlap between adjacent chunks
RETRIEVAL_TOP_K=20          # candidates from vector search
RERANK_TOP_N=6              # chunks kept after re-ranking
HYDE_ENABLED=true           # Hypothetical Document Embeddings
HYBRID_ALPHA=0.7            # 1.0 = pure vector, 0.0 = pure keyword
MAX_CONTEXT_TOKENS=6000     # max tokens sent to LLM as context
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Semantic Cache ────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.93

# ── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Confidence Thresholds ─────────────────────────────────────
CONFIDENCE_HIGH=0.78
CONFIDENCE_MEDIUM=0.58
