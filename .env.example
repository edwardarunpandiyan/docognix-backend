# ============================================================
# Docognix Backend – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="Docognix API"
APP_VERSION="1.0.0"
DEBUG=false
API_PREFIX="/api/v1"

# ── CORS (comma-separated list is fine for pydantic-settings)
# Add your Vercel/Netlify URL when deployed
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'

# ── Supabase PostgreSQL ───────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Upstash Redis ─────────────────────────────────────────────
# Upstash Console → Your Database → Details → Redis URL
UPSTASH_REDIS_URL=rediss://default:<token>@<hostname>.upstash.io:6379
UPSTASH_REDIS_TOKEN=<your-upstash-rest-token>

# ── Groq API (FREE at groq.com) ───────────────────────────────
GROQ_API_KEY=gsk_<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ── Model Mode ────────────────────────────────────────────────
# true  → run embedding + reranker locally (requires torch, ~400 MB RAM)
# false → use HuggingFace Inference API   (no torch, ~100 MB RAM — use for Render free tier)
USE_LOCAL_MODELS=false

# ── HuggingFace Inference API ─────────────────────────────────
# Required when USE_LOCAL_MODELS=false.
# Free token at: https://huggingface.co/settings/tokens (Read access is enough)
HF_API_TOKEN=hf_<your-huggingface-token>

# ── Embedding & Reranker Models ───────────────────────────────
# These are read by both local and API modes — do not hardcode in source files.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── RAG Pipeline Tuning ───────────────────────────────────────
CHUNK_SIZE=300              # target tokens per chunk
CHUNK_OVERLAP=40            # overlap between adjacent chunks
RETRIEVAL_TOP_K=20          # candidates from vector search
RERANK_TOP_N=6              # chunks kept after re-ranking
RERANK_MIN_RATIO=0.40       # prune chunks below 40 % of top CE score
HYDE_ENABLED=true           # Hypothetical Document Embeddings
HYBRID_ALPHA=0.7            # 1.0 = pure vector, 0.0 = pure keyword
MAX_CONTEXT_TOKENS=6000     # max tokens sent to LLM as context
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ── Semantic Cache ────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.93

# ── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Confidence Thresholds ─────────────────────────────────────
CONFIDENCE_HIGH=0.70
CONFIDENCE_MEDIUM=0.35
